<form action="<%= action %>" method="POST" class="post-form">

        <div class="form-group">
            <label for="title">Title</label>
            <input
                type="text"
                id="title"
                name="title"
                value="<%= post.title  || " "%> " 
                maxlength="100"
                required
            >
        </div>

        <div class="form-group">
            <label for="subheading">Subheading</label>
            <input
                type="text"
                id="subheading"
                name="subheading"
                maxlength="300"
                value="<%= post.subheading || " "%>"
            >
        </div>

        <div class="form-group">
            <label for="content">Content</label>
            <textarea
                id="content"
                name="content"
                rows="10"
                required
            ><%= post.content || " "%></textarea>
        </div>
        <div class="form-group">
            <label for="imageURL">Image URL</label>
            <textarea
                id="imageurl"
                name="imageurl"
                
            ><%= post.imageurl || " "%></textarea>
        </div>
        <div class="btn-box">
        <!--Cancel button-->
        <a href="/posts/<%= post.id%>" class="btn cancel-btn"><span class="label">Cancel</span></a>
        <!--Save button-->
        <button type="submit" class="btn save-post"><span class="label"><%= buttonText %></span></button></div>
    </form>