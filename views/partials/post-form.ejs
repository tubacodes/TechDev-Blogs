<form action="<%= action %>" method="POST" class="post-form" enctype="multipart/form-data">

        <div class="form-group">
            <label for="title">Title</label>
            <input
                type="text"
                id="title"
                name="title"
                value="<%= post.title  || " "%> " 
                maxlength="100"
                required
            >
        </div>

        <div class="form-group">
            <label for="subheading">Subheading</label>
            <input
                type="text"
                id="subheading"
                name="subheading"
                maxlength="300"
                value="<%= post.subheading || " "%>"
            >
        </div>

        <div class="form-group">
            <label for="content">Content</label>
            <textarea
                id="content"
                name="content"
                rows="10"
                required
            ><%= post.content || " "%></textarea>
        </div>
        <div class="form-group">
  <label for="image">Post image</label>
  <input
    type="file"
    class="form-control-file"
    id="image"
    name="image"
    accept="image/*"
  >

  <% if (post && post.imageurl) { %>
    <div class="current-image-preview">
      <p class="current-image-label">Current image:</p>
      <img src="<%= post.imageurl %>" alt="Current post image" class="preview-thumb">
    </div>
  <% } %>
</div>
        <div class="btn-box">
        <!--Cancel button-->
        <a href="/posts/<%= post.id%>" class="btn cancel-btn"><span class="label">Cancel</span></a>
        <!--Save button-->
        <button type="submit" class="btn save-post"><span class="label"><%= buttonText %></span></button></div>
    </form>